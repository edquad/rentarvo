# Database
DATABASE_URL=postgresql://rentarvo:rentarvo_dev@localhost:5432/rentarvo?schema=public

# Auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Storage (local disk — default for development)
STORAGE_DRIVER=local
UPLOAD_DIR=./rentarvo-api/uploads
MAX_UPLOAD_MB=25

# Storage (S3 — use in production for leases, bills, photos)
# STORAGE_DRIVER=s3
# S3_BUCKET=rentarvo-documents-your-account-id
# AWS_REGION=us-east-1
# S3_PREFIX=rentarvo
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# LLM (chatbot)
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
API_PORT=4000
WEB_PORT=5173
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
